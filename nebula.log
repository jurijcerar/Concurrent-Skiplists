			summary_line=$(echo "$RESULT" | grep "Summary:"); \
			echo "Threads,Duration,Total_Operations,Successful_Operations,Insert_Success,Delete_Success,Contains_Success,Throughput" > data/skiplist4/results-threads-$threads-duration-$duration-mix-$(echo $operation_mix | tr ' ' '-')-$range_type.csv; \
			echo "$summary_line" | awk -F', ' ' \
				BEGIN { OFS=","; } \
				{ \
					for (i = 1; i <= NF; i++) { \
						split($i, pair, "="); \
						values[i] = pair[2]; \
					} \
					print values[1], values[2], values[3], values[4], values[5], values[6], values[7], values[8]; \
				}' >> data/skiplist4/results-threads-$threads-duration-$duration-mix-$(echo $operation_mix | tr ' ' '-')-$range_type.csv; \
		done; \
	done; \
done
