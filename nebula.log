Running benchmarks for skiplist...
for operation_mix in "10 10 80" "40 40 20"; do \
	RESULT=$(./build/skiplist --threads 1 --experiments 1 --duration 1 --operations $operation_mix --key_range 0 100000 --strategy RANDOM --seed 12345 --prefill 0 --range_type COMMON); \
	summary_line=$(echo "$RESULT" | grep "Summary:"); \
	echo "Threads,Duration,Total_Operations,Successful_Operations,Insert_Success,Delete_Success,Contains_Success,Throughput" > data/skiplist/results-threads-1-duration-$duration-mix-$(echo $operation_mix | tr ' ' '-').csv; \
	echo "$summary_line" | awk -F', ' ' \
		BEGIN { OFS=","; } \
		{ \
			for (i = 1; i <= NF; i++) { \
				split($i, pair, "="); \
				values[i] = pair[2]; \
			} \
			print values[1], values[2], values[3], values[4], values[5], values[6], values[7], values[8]; \
		}' >> data/skiplist/results-threads-1-duration-$duration-mix-$(echo $operation_mix | tr ' ' '-').csv; \
done; \

Running benchmarks for skiplist3...
for threads in 1 2 4 8 16 64; do \
	for operation_mix in "10 10 80"; do \
		RESULT=$(./build/skiplist3 --threads $threads --experiments 1 --duration 1 --operations $operation_mix --key_range 0 100000 --strategy RANDOM --seed 12345 --prefill 0 --range_type COMMON); \
		summary_line=$(echo "$RESULT" | grep "Summary:"); \
		echo "Threads,Duration,Total_Operations,Successful_Operations,Insert_Success,Delete_Success,Contains_Success,Throughput" > data/skiplist3/results-threads-$threads-duration-$duration-mix-$(echo $operation_mix | tr ' ' '-').csv; \
		echo "$summary_line" | awk -F', ' ' \
			BEGIN { OFS=","; } \
			{ \
				for (i = 1; i <= NF; i++) { \
					split($i, pair, "="); \
					values[i] = pair[2]; \
				} \
				print values[1], values[2], values[3], values[4], values[5], values[6], values[7], values[8]; \
			}' >> data/skiplist3/results-threads-$threads-duration-$duration-mix-$(echo $operation_mix | tr ' ' '-').csv; \
	done; \
done
